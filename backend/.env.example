# Backend Environment Variables for Farm-Nimbus
# Copy this to .env and fill in your values

# MongoDB (use MongoDB Atlas free tier)
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
DB_NAME=farm_nimbus

# OpenWeatherMap API (free tier available)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Twilio SMS/Voice (see SMS_VOICE_SETUP.md)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Optional AI Services
OPENAI_API_KEY=your_openai_key_here
GOOGLE_AI_API_KEY=your_google_ai_key_here

# CORS Origins (comma separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# JWT Secret
JWT_SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Expert Dashboard Secret Key
EXPERT_SECRET_KEY=your_expert_secret_key_here

# Debug
DEBUG=true
